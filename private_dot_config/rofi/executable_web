#!/usr/bin/env bash
set -euo pipefail

browser="${ROFI_WEB_BROWSER:-firefox}"
browser_new_tab_arg="${ROFI_WEB_BROWSER_NEW_TAB_ARG:---new-tab}"
browser_window_class="${ROFI_WEB_BROWSER_CLASS:-firefox}"
focus_start_delay="${ROFI_WEB_FOCUS_START_DELAY:-0.2}"
focus_retries="${ROFI_WEB_FOCUS_RETRIES:-10}"
focus_delay="${ROFI_WEB_FOCUS_DELAY:-0.1}"

open_new_tab() {
  "$browser" "$browser_new_tab_arg" "$1" >/dev/null 2>&1 &
  disown
}

focus_browser() {
  command -v xdotool >/dev/null 2>&1 || return 0

  for ((attempt = 1; attempt <= focus_retries; attempt++)); do
    window_id="$(xdotool search --onlyvisible --class "$browser_window_class" 2>/dev/null | tail -n 1 || true)"

    if [ -n "$window_id" ]; then
      xdotool windowactivate "$window_id" >/dev/null 2>&1 || true
      return 0
    fi

    sleep "$focus_delay"
  done
}

focus_browser_later() {
  (
    sleep "$focus_start_delay"
    focus_browser
  ) >/dev/null 2>&1 &
  disown
}

url_encode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))' "$1"
}

open_google_or_url() {
  target="$1"

  case "$target" in
    http://*|https://*|www.*)
      open_new_tab "$target"
      ;;
    *)
      encoded_target="$(url_encode "$target")"
      open_new_tab "https://www.google.com/search?q=${encoded_target}"
      ;;
  esac
}

input="${1:-}"

[ -z "$input" ] && exit 0

open_google_or_url "$input"
focus_browser_later
