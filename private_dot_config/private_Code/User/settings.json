{
    "window.autoDetectColorScheme": true,
    "workbench.preferredLightColorTheme": "Dark 2026",
    "chat.viewSessions.orientation": "stacked",
    "jdk.telemetry.enabled": false

    // Disable AI/Copilot suggestions
    "github.copilot.enable": {
        "*": false
    },
    
    // Disable standard editor autocomplete/suggestions
    // "editor.suggestOnTriggerCharacters": false,
    // "editor.quickSuggestions": {
    //     "other": false,
    //     "comments": false,
    //     "strings": false
    // },
    "editor.acceptSuggestionOnEnter": "off",
    
    // Disable parameter hints and lightbulbs
    // "editor.parameterHints.enabled": false,
    // "editor.lightbulb.enabled": false,
    
    // Disable AI chat features
    "chat.editor.autoImportSuggestions": false
}
