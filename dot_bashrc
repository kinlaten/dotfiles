gsa4() {
    local input output default_output

    if [[ $# -lt 1 ]]; then
        echo "Usage: gsa4 <input.pdf> [output.pdf]" >&2
        return 1
    fi

    input=$1

    if [[ ! -f "$input" ]]; then
        echo "Input file not found: $input" >&2
        return 1
    fi

    default_output="${input%.pdf}-A4.pdf"
    output=${2:-$default_output}

    /usr/bin/gs \
      -o "$output" \
      -sDEVICE=pdfwrite \
      -sPAPERSIZE=a4 \
      -dFIXEDMEDIA \
      -dPDFFitPage \
      "$input"
}



bat() {
  local battery="${1:-BAT0}"
  local base="/sys/class/power_supply/$battery"

  if [[ ! -d "$base" ]]; then
    echo "battery not found: $battery" >&2
    echo "available:" >&2
    ls /sys/class/power_supply >&2
    return 1
  fi

  local status capacity
  status=$(<"$base/status")
  capacity=$(<"$base/capacity")

  printf "%s: %s%% (%s)\n" "$battery" "$capacity" "$status"
}

