#
# Patch rename in vim
# 
virn(){
    local old=$(mktemp)
    local new=$(mktemp)
    
    ls -1  --group-directories-first > "$old"
    cp "$old" "$new"
    nvim "$new"

    paste "$old" "$new" | while IFS=$'\t' read -r src dest; do
        [ "$src" != "$dest" ] && mv -iv "$src" "$dest" 
    done

    rm "$old" "$new"
}

# log directory history (unique consecutive entries)
_log_pwd() {
  local last current
  current=$(pwd)

  # read last line if file exists and is non-empty
  if [ -s "${HOME}/.bash_dh" ]; then
    last=$(tail -n 1 "${HOME}/.bash_dh")
  fi

  # only append if different from previous
  if [ "$current" != "$last" ]; then
    printf '%s\n' "$current" >> "${HOME}/.bash_dh"
  fi
}


# Directory history jump
dh() {
  local dir
  [ -f "${HOME}/.bash_dh" ] || { echo "No dir history yet."; return 1; }

  dir=$(tac "${HOME}/.bash_dh" | awk '!seen[$0]++' | fzf) || return 1
  [ -d "$dir" ] && cd "$dir"
}



gen-desktop() {
    local bin="" name="" icon="" desktop_name=""
    local bin_only=false

    # Help text
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        echo "Usage:"
        echo "  gen-desktop                           # interactive"
        echo "  gen-desktop -b <binary> [name] [icon] # batch"
        echo "  gen-desktop -B <binary>               # batch, attempt auto‑name/icon"
        return 0
    fi

    # Decide mode
    if [[ "$1" == "-b" ]]; then
        # batch: -b <binary> [name] [icon]
        if [[ -z "$2" ]]; then
            echo "Error: missing binary path with -b." >&2
            return 1
        fi
        bin="$2"
        name="${3:-${bin##*/}}"   # default to basename
        icon="${4:-}"

        if [[ ! -x "$bin" ]]; then
            echo "Error: binary not found or not executable: $bin" >&2
            return 1
        fi

    elif [[ "$1" == "-B" ]]; then
        # batch auto: -B <binary>
        if [[ -z "$2" ]]; then
            echo "Error: missing binary path with -B." >&2
            return 1
        fi
        bin="$2"
        name="${bin##*/}"
        desktop_name="$name"

        if [[ -x "$bin" ]]; then
            icon=""
            while IFS= read -r -d '' f; do
                if [[ "$f" =~ \.(png|svg|jpg|jpeg)$ ]]; then
                    icon="$f"
                    break
                fi
            done < <(find "$HOME/.local/share/icons" "$HOME/.icons" /usr/share/icons -type f -printf '%p\0' 2>/dev/null)
        else
            echo "Error: binary not found or not executable: $bin" >&2
            return 1
        fi

    else
        # interactive
        while [[ -z "$bin" ]]; do
            read -rp "Binary path (executable): " bin
            if [[ -z "$bin" ]]; then
                echo "Binary path is required; aborting." >&2
                return 1
            elif [[ ! -x "$bin" ]]; then
                echo "Binary not found or not executable: $bin"
                bin=""
            fi
        done
        read -rp "Application display name [${bin##*/}]: " name
        [[ -z "$name" ]] && name="${bin##*/}"
        read -rp "Icon path (optional): " icon
    fi

    # Sanitize desktop name
    desktop_name="$(printf '%s' "$name" | sed -E 's/[^a-zA-Z0-9._-]+/_/g' | sed -E 's/^_+|_+$//')"

    # Ensure desktop dir exists
    local desktop_dir="$HOME/.local/share/applications"
    [[ -d "$desktop_dir" ]] || mkdir -p "$desktop_dir"

    # Default icon guess if not given
    if [[ -z "$icon" ]]; then
        icon="$bin.desktop.icon"
    fi

    # Construct .desktop content
    cat > "$desktop_dir/${desktop_name}.desktop" << EOF
[Desktop Entry]
Type=Application
Name=$name
Exec=$bin
Comment=Launched from gen-desktop
Icon=$icon
Terminal=false
Categories=Utility;
EOF
    chmod +x "$desktop_dir/${desktop_name}.desktop"

    echo "Desktop file created:"
    echo "  $desktop_dir/${desktop_name}.desktop"
    echo "You may need to run:  gtk‑update‑icon‑cache ~/.local/share/icons  (if you added icons)"
}


