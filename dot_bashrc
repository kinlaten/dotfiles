# hisfc (no args)
#
# interactively search, fix and run command in history
#
hisfc() {
  local target_command temp_file
  temp_file=$(mktemp)

  # Use 'history' and tail to get the last 1000 items
  history | tail -n 1000 | fzf --tac | sed 's/^[ ]*[0-9]*[ ]*//' >"$temp_file"

  if [[ ! -s "$temp_file" ]]; then
    rm -f "$temp_file"
    return 0
  fi

  command nvim "$temp_file"
  # Execute with bash instead of zsh
  bash "$temp_file"
  command rm "$temp_file"
}

# lp <file-pdf>
