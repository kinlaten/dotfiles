clip() {
  # We use a local alias or just call the command directly
  local copy="xclip -sel clip"

  if [[ $# -gt 0 ]]; then
    # Case: Args exist. Cat the files and pipe to xclip.
    cat "$@" | $copy
  else
    # Case: No args. xclip reads directly from the pipe (stdin).
    $copy
  fi
}

