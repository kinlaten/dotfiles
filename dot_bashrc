lp() {
  local page pageNumber
  read -p "Pages (all, custom): " page

  if [[ "$page" == "all" ]]; then
    command lp -d Brother_HL_L2400DW -o fit-to-page -o media=legal/A4/letter -o sides=two-sided-long-edge "$1"
  elif [[ "$page" == "custom" ]]; then
    read -p "Pages number (#-#): " pageNumber
    command lp -d Brother_HL_L2400DW -P "$pageNumber" -o fit-to-page -o media=legal/A4/letter -o sides=two-sided-long-edge "$1"
  else
    echo "Invalid option selected."
  fi
}

