b () 
{ 
    local file="$HOME/bookmarks.json";
    [ ! -f "$file" ] && echo "No bookmarks file" && return 1;
    local sel url;
    sel=$(jq -r '
        def walk(path):
          if type == "object" and has("url") then
            [ (path | join("/")), .title, .url ] | @tsv
          elif type == "object" then
            to_entries[] | (.value | walk(path + [.key]))
          elif type == "array" then
            .[] | walk(path)
          else
            empty
          end;
        walk([])
    ' "$file" | fzf --delimiter=$'\t' --with-nth=1,2,3);

    [ -z "$sel" ] && return;
    url=$(printf "%s" "$sel" | cut -f3);
    [ -n "$url" ] && firefox -new-tab "$url" > /dev/null 2>&1 &
}

